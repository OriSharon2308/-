# מפתח API אחד לכל 4 הסוכנים — לא צריך מפתח לכל סוכן!

# --- Claude (מומלץ) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- או OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

SAFE_CHILD_MODE=true
# PORT=8787

# --- Azure Speech (דיבור: STT + TTS) ---
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# ניקוד עברי (Dicta) — כבוי כברירת מחדל; יאומת בשלב שלו
NIKUD_ENABLED=false

# קול TTS (אופציונלי) — ברירת מחדל Hila HD. להשוואת קול גברי:
# AZURE_TTS_VOICE=he-IL-Avri:DragonHDOmniLatestNeural

# --- ספק TTS: azure (ברירת מחדל) או google (Gemini/Orus דרך Vertex AI + ADC) ---
TTS_PROVIDER=google
# Google Cloud (TTS דרך Vertex; אימות ADC עם gcloud — בלי קובץ מפתח בפרויקט)
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1
GOOGLE_TTS_VOICE=Orus
